{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "notification:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "fasting:default",
    "health-connect:default",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://openrouter.ai/*" }]
    }
  ]
}
